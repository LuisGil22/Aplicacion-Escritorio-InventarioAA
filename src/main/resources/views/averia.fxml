<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inventario.controllers.AveriaController"
            stylesheets="@../css/parametros.css"
            styleClass="vbox">

    <HBox spacing="10" style="-fx-padding: 5 10 5 10;">
        <Label fx:id="lblActualizado" text="Actualizado: "
               style="-fx-font-size: 16px;" HBox.hgrow="NEVER" />
        <Pane HBox.hgrow="ALWAYS"/>
        <HBox spacing="10" alignment="CENTER">
            <Button text="Modificar" onAction="#onEditAveria" styleClass="action-button"/>
            <Button text="Eliminar" onAction="#onDeleteAveria" styleClass="action-button"/>
            <Button text="Observaciones" onAction="#abrirObservacionesAverias" styleClass="action-button"/>
        </HBox>
        <Pane HBox.hgrow="ALWAYS"/>
    </HBox>

    <TableView fx:id="tablaAverias" styleClass="table-view-cond">
        <columns>
            <TableColumn fx:id="colNumAveria" prefWidth="140">
                <graphic>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="NUM_AVERIA"/>
                        <Button fx:id="btnFiltroNumAveria" text="▼" style="-fx-background-color: transparent; -fx-font-size: 10px;" onAction="#configurarFiltroNumAveria"/>
                    </HBox>
                </graphic>
            </TableColumn>
            <TableColumn fx:id="colEquipoAveriado" prefWidth="180">
                <graphic>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="EQUIPO_AVERIADO"/>
                        <Button fx:id="btnFiltroEquipoAveriado" text="▼" style="-fx-background-color: transparent; -fx-font-size: 10px;" onAction="#configurarFiltroEquipoAveriado"/>
                    </HBox>
                </graphic>
            </TableColumn>
            <TableColumn fx:id="colCodigo" prefWidth="100">
                <graphic>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="CODIGO"/>
                        <Button fx:id="btnFiltroCodigo" text="▼" style="-fx-background-color: transparent; -fx-font-size: 10px;" onAction="#configurarFiltroCodigo"/>
                    </HBox>
                </graphic>
            </TableColumn>
            <TableColumn fx:id="colEstado" prefWidth="100">
                <graphic>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="ESTADO"/>
                        <Button fx:id="btnFiltroEstado" text="▼" style="-fx-background-color: transparent; -fx-font-size: 10px;" onAction="#configurarFiltroEstado"/>
                    </HBox>
                </graphic>
            </TableColumn>
            <TableColumn fx:id="colPlanta" prefWidth="100">
                <graphic>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="PLANTA"/>
                        <Button fx:id="btnFiltroPlanta" text="▼" style="-fx-background-color: transparent; -fx-font-size: 10px;" onAction="#configurarFiltroPlanta"/>
                    </HBox>
                </graphic>
            </TableColumn>
            <TableColumn fx:id="colLocalizacion" prefWidth="140">
                <graphic>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="LOCALIZACION"/>
                        <Button fx:id="btnFiltroLocalizacion" text="▼" style="-fx-background-color: transparent; -fx-font-size: 10px;" onAction="#configurarFiltroLocalizacion"/>
                    </HBox>
                </graphic>
            </TableColumn>
            <TableColumn fx:id="colFechaAveria" prefWidth="160">
                <graphic>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="FECHA_AVERIA"/>
                        <Button fx:id="btnFiltroFechaAveria" text="▼" style="-fx-background-color: transparent; -fx-font-size: 10px;" onAction="#configurarFiltroFechaAveria"/>
                    </HBox>
                </graphic>
            </TableColumn>
            <TableColumn fx:id="colMail" prefWidth="160">
                <graphic>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="MAIL"/>
                        <Button fx:id="btnFiltroMail" text="▼" style="-fx-background-color: transparent; -fx-font-size: 10px;" onAction="#configurarFiltroMail"/>
                    </HBox>
                </graphic>
            </TableColumn>
            <TableColumn fx:id="colObservaciones" prefWidth="190" text="OBSERVACIONES" styleClass="col-observaciones"/>
        </columns>
    </TableView>

</VBox>
